#------------------------------------------------------------------------------
# Azure Document Intelligence - Credentials Template
#
# Copy this file to credentials.tfvars and populate with real values.
# credentials.tfvars is git-ignored — NEVER commit it.
#
# Pass at plan/apply time:
#   terraform plan  -var-file="config/credentials.tfvars" -var-file="config/project.tfvars" ...
#   terraform apply -var-file="config/credentials.tfvars" -var-file="config/project.tfvars" ...
#
# To create a service principal:
#   az ad sp create-for-rbac --name "docintel-terraform" \
#     --role Contributor \
#     --scopes /subscriptions/<subscription-id>
#------------------------------------------------------------------------------

arm_subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # Azure subscription ID
arm_tenant_id       = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # Entra ID tenant ID
arm_client_id       = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # Service principal client ID
arm_client_secret   = "your-client-secret-here"               # Service principal secret
