<mxfile host="app.diagrams.net">
  <diagram id="solution-architecture" name="Solution Architecture">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- INSTRUCTIONS                                                -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="instructions" value="📝 EDITING THIS DIAGRAM:&#xa;• Replace placeholder labels with your solution's service names&#xa;• Add or remove shapes as needed — all shapes are generic (no vendor pack required)&#xa;• To connect shapes: press C and drag between them&#xa;• To export PNG: File → Export as → PNG (300 DPI, 10px border)&#xa;• Save as: architecture-diagram.png&#xa;&#xa;For automated PNG generation: edit and run generate_diagram.py"
          style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;"
          vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="420" height="120" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TITLE                                                       -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="title" value="[Solution Name] — Architecture"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="460" y="40" width="700" height="40" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- EXTERNAL / ON-PREMISES                                      -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="ext-cluster" value="External / On-Premises"
          style="swimlane;startSize=25;fillColor=#f0f0f0;strokeColor=#999999;fontStyle=1;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ext-1" value="[External System]"
          style="rounded=1;fillColor=#f0f0f0;strokeColor=#666666;fontSize=11;"
          vertex="1" parent="ext-cluster">
          <mxGeometry x="25" y="45" width="150" height="50" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- LAYER 1: INGESTION / FRONTEND                               -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="layer1-cluster" value="[Layer 1: e.g. Ingestion / Frontend]"
          style="swimlane;startSize=25;fillColor=#E8F4FD;strokeColor=#0078d4;fontStyle=1;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="320" y="160" width="400" height="120" as="geometry" />
        </mxCell>
        <mxCell id="layer1-svc1" value="[Service 1]"
          style="rounded=1;fillColor=#dae8fc;strokeColor=#0078d4;fontSize=11;"
          vertex="1" parent="layer1-cluster">
          <mxGeometry x="30" y="45" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="layer1-svc2" value="[Service 2]"
          style="rounded=1;fillColor=#dae8fc;strokeColor=#0078d4;fontSize=11;"
          vertex="1" parent="layer1-cluster">
          <mxGeometry x="220" y="45" width="150" height="50" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- LAYER 2: PROCESSING / APPLICATION                           -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="layer2-cluster" value="[Layer 2: e.g. Processing / Application]"
          style="swimlane;startSize=25;fillColor=#FDF8E8;strokeColor=#d6a800;fontStyle=1;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="320" y="340" width="400" height="120" as="geometry" />
        </mxCell>
        <mxCell id="layer2-svc1" value="[Service 3]"
          style="rounded=1;fillColor=#fff2cc;strokeColor=#d6a800;fontSize=11;"
          vertex="1" parent="layer2-cluster">
          <mxGeometry x="30" y="45" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="layer2-svc2" value="[Service 4]"
          style="rounded=1;fillColor=#fff2cc;strokeColor=#d6a800;fontSize=11;"
          vertex="1" parent="layer2-cluster">
          <mxGeometry x="220" y="45" width="150" height="50" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- LAYER 3: DATA / STORAGE                                     -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="layer3-cluster" value="[Layer 3: e.g. Data / Storage]"
          style="swimlane;startSize=25;fillColor=#E8F8F5;strokeColor=#00897b;fontStyle=1;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="320" y="520" width="400" height="120" as="geometry" />
        </mxCell>
        <mxCell id="layer3-svc1" value="[Service 5]"
          style="rounded=1;fillColor=#d5e8d4;strokeColor=#00897b;fontSize=11;"
          vertex="1" parent="layer3-cluster">
          <mxGeometry x="30" y="45" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="layer3-svc2" value="[Service 6]"
          style="rounded=1;fillColor=#d5e8d4;strokeColor=#00897b;fontSize=11;"
          vertex="1" parent="layer3-cluster">
          <mxGeometry x="220" y="45" width="150" height="50" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- SECURITY / OPERATIONS (right column)                        -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="sec-cluster" value="[Security / Operations]"
          style="swimlane;startSize=25;fillColor=#FDE8E8;strokeColor=#cc0000;fontStyle=1;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="800" y="160" width="220" height="300" as="geometry" />
        </mxCell>
        <mxCell id="sec-svc1" value="[Security Service 1]"
          style="rounded=1;fillColor=#f8cecc;strokeColor=#cc0000;fontSize=11;"
          vertex="1" parent="sec-cluster">
          <mxGeometry x="30" y="45" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sec-svc2" value="[Security Service 2]"
          style="rounded=1;fillColor=#f8cecc;strokeColor=#cc0000;fontSize=11;"
          vertex="1" parent="sec-cluster">
          <mxGeometry x="30" y="120" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sec-svc3" value="[Monitoring]"
          style="rounded=1;fillColor=#f8cecc;strokeColor=#cc0000;fontSize=11;"
          vertex="1" parent="sec-cluster">
          <mxGeometry x="30" y="195" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- CONNECTIONS — replace with actual data flows                -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="e1" value="[flow label]"
          style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0078d4;fontSize=9;"
          edge="1" source="ext-1" target="layer1-svc1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="[flow label]"
          style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6a800;fontSize=9;"
          edge="1" source="layer1-svc1" target="layer2-svc1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="[flow label]"
          style="edgeStyle=orthogonalEdgeStyle;strokeColor=#00897b;fontSize=9;"
          edge="1" source="layer2-svc1" target="layer3-svc1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="[monitoring]"
          style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#cc0000;fontSize=9;"
          edge="1" source="layer2-svc1" target="sec-svc3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- LEGEND                                                      -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="legend" value="Legend: Solid arrows = synchronous flow  |  Dashed arrows = async / monitoring"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontStyle=2;"
          vertex="1" parent="1">
          <mxGeometry x="300" y="680" width="600" height="25" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
